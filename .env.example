NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

DATABASE_URL=postgresql://broadcast:broadcast@localhost:5432/broadcast_erp?schema=public
DIRECT_DATABASE_URL=postgresql://broadcast:broadcast@localhost:5432/broadcast_erp?schema=public

JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
PASSWORD_RESET_TTL_MINUTES=30
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMeNow123!
SUPER_ADMIN_NAME=System Administrator

FIELD_ENCRYPTION_KEY=base64-encoded-32-byte-key
FIELD_ENCRYPTION_KEY_VERSION=1

REDIS_URL=redis://localhost:6379

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=broadcast-erp
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123

CORS_ORIGINS=http://localhost:3000,http://localhost:1420
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=20
METRICS_ENABLED=true
TRUST_PROXY=false
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:1420
BACKUP_SCHEDULE_CRON=0 2 * * *
LOG_LEVEL=info
