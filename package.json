{
  "name": "broadcast-operations-erp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @broadcast/database prisma:generate",
    "db:migrate:dev": "pnpm --filter @broadcast/database prisma:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @broadcast/database prisma:migrate:deploy"
  },
  "devDependencies": {
    "@broadcast/eslint-config": "workspace:*",
    "@broadcast/typescript-config": "workspace:*",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
